# Copy to terraform.tfvars (gitignored) and set real values.
# Never commit terraform.tfvars — it is gitignored under deployment/terraform/envs/*/.
#
# region — used for regional GCP resources (Cloud SQL, Redis) and as the default
#          GCS *location* for the Terraform state bucket when deploy-platform.sh creates it
#          (override with arg 3 or GCS_STATE_BUCKET_LOCATION). Default bucket name is
#          <project_id>-tfstate-<env> (see deployment/scripts/terraform-deploy.sh).
#          (Terraform does not create a separate app GCS bucket unless create_application_gcs_bucket = true.)

project_id = "your-gcp-project-id"
region     = "us-central1"

# Optional: set false if you create estateflow-admin-db / estateflow-redis Secrets with kubectl or External Secrets.
# create_app_runtime_secrets = true

# Jenkins Workload Identity (default true): GCP SA + IAM + Kubernetes ServiceAccount jenkins + namespace admin RoleBinding.
# enable_jenkins_workload_identity = false
# Use one shared account id only in a single env root (both dev+prod in same project need different ids or import one SA).
# jenkins_gcp_sa_account_id = "jenkins-sa"

# Optional: extra Artifact Registry repo IAM (e.g. your Google user for local docker push to estateflow-<env>).
# artifact_registry_repository_iam_extras = [
#   { member = "user:you@gmail.com", role = "roles/artifactregistry.writer" },
# ]
